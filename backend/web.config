<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add
        name="Python FastCGI"
        path="*"
        verb="*"
        modules="FastCgiModule"
        scriptProcessor="%HOME%\\Python312\\python.exe|%HOME%\\Python312\\Lib\\site-packages\\wfastcgi.py"
        resourceType="Unspecified"
        requireAccess="Script" />
    </handlers>
  </system.webServer>
  <appSettings>
    <add key="WSGI_HANDLER" value="app.app" />
    <add key="PYTHONPATH" value="%HOME%\\site\\wwwroot" />
  </appSettings>
</configuration>
